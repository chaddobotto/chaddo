{
  "name": "mog-bot",
  "version": "0.0.1",
  "private": true,
  "description": "The ultimate framework for mogging other bots into submission",
  "keywords": [
    "mog",
    "mogging",
    "bot",
    "framework",
    "superiority",
    "dominance",
    "automation"
  ],
  "author": "The MOG Bot Team",
  "license": "MIT",
  "homepage": "https://github.com/mogbot/mog-bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/mogbot/mog-bot.git"
  },
  "bugs": {
    "url": "https://github.com/mogbot/mog-bot/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
